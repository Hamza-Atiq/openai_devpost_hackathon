# Runtime mode is always explicit. Local and test disable live services by default.
CRICKOPS_ENV=local
CRICKOPS_LIVE_SERVICES_ENABLED=false

# Server only. Use platform secret management in preview and production.
DATABASE_URL=
OPENAI_API_KEY=
CRICKOPS_COOKIE_SECRET=
CRICKOPS_ENCRYPTION_SECRET=
CRICKOPS_ALLOWED_FRONTEND_ORIGINS=

# Browser allowlist. Keep the API same-origin unless deployment requires otherwise.
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_BUILD_SHA=
